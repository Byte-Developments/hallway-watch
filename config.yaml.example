# Copy to config.yaml and edit for your setup:
#   cp config.yaml.example config.yaml

camera:
  device: 0
  width: 800          # higher res helps distant heads (Pi 4/5)
  height: 600
  fps: 8              # slightly lower fps frees CPU for larger imgsz

detection:
  model: models/yolov8n.pt
  confidence: 0.42    # lower = catch dim/distant heads (pair with confirm_frames)
  motion_threshold: 18
  motion_min_area: 600   # smaller blobs count (distant movement)
  alert_cooldown_seconds: 15   # min gap between separate visits (backup)
  visit_clear_frames: 12       # empty frames before someone counts as "left"
  low_light_enhance: true
  clahe_clip_limit: 4.0
  clahe_tile_size: 8
  gamma: 1.35           # brighten dark frames; auto-boosts when very dark
  denoise: true
  head_height_fraction: 0.45
  small_box_height: 100   # boxes below this px → treat as distant head-only
  imgsz: 736              # larger inference helps small/distant people
  confirm_frames: 2       # consecutive hits before alert (cuts false positives)
  # Optional: black-and-white PNG mask (white = watch, black = ignore)
  # roi_mask: assets/roi_mask.png

audio:
  enabled: true
  sound_file: assets/sounds/alert.wav
  device: default

notifications:
  enabled: true
  host: 0.0.0.0
  port: 8765
  title: Hallway Alert
  message: Someone is in the hallway
  tls_enabled: true
  tls_cert: certs/cert.pem
  tls_key: certs/key.pem
  vapid_contact: mailto:hallway-watch@local

snapshots:
  enabled: true
  dir: snapshots

logging:
  level: INFO
  debug_level: DEBUG
  detection_log_dir: logs/detections
  debug_log_dir: logs/debug
